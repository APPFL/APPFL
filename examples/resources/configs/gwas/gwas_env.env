# GWAS pipeline configuration
# Use_cuML: set to true to use cuML (GPU) instead of scikit-learn for regressions
Use_cuML=false

# Variant_Scaling: fraction of variants to use (0.0 to 1.0)
# 1.0 = all variants (default); 0.5 = random 50% (deterministic seed)
Variant_Scaling=0.1

# Hit_P_Threshold: genome-wide significance threshold for hit detection and Manhattan plot lines
# Applied in baseline GWAS, site-level GWAS, and server meta-analysis aggregator
Hit_P_Threshold=5e-8

# Data_Sim_Scaling: fraction of BIM variants to retain at data simulation stage (0.0–1.0)
# Applied before PGS overlap in simulate_phenotypes.py and before site BED writing in data_bundler.py
# Distinct from Variant_Scaling (analysis-time); they compound: 0.7 * 0.6 = 0.42 of all variants
Data_Sim_Scaling=0.02
